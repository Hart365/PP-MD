{
  "name": "pp-md",
  "private": true,
  "version": "1.1.5",
  "description": "Power Platform solution documentation generator for Windows desktop.",
  "author": "Mike Hartley",
  "companyName": "Hart of the Midlands",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "check:contrast": "node scripts/check-contrast.mjs",
    "smoke:doc": "tsx scripts/smoke-doc.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:a11y": "playwright test -c playwright.a11y.config.ts",
    "quality:gate": "npm run lint && npm run test:run && npm run smoke:doc && npm run build && npm run test:a11y",
    "build": "npm run check:contrast && tsc && vite build",
    "build:with-maps": "npm run check:contrast && tsc && vite build --mode debug",
    "desktop:stamp": "node scripts/stamp-exe.mjs",
    "desktop:build:latest": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-latest.ps1",
    "desktop:build:latest:skip-build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-latest.ps1 -SkipBuild",
    "phase:complete": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/phase-complete.ps1",
    "desktop:build": "npm run build && set PPMD_FLAVOR=portable&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable",
    "desktop:build:installer": "npm run build && set PPMD_FLAVOR=installer&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis",
    "preview": "vite preview",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.12.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "rcedit": "^5.0.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.5"
  },
  "build": {
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "appId": "com.ppmd.desktop",
    "productName": "PP-MD",
    "asar": true,
    "compression": "maximum",
    "copyright": "Copyright (c) Mike Hartley, Hart of the Midlands",
    "forceCodeSigning": false,
    "extraMetadata": {
      "author": "Mike Hartley",
      "companyName": "Hart of the Midlands"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "executableName": "PP-MD",
      "icon": "build/icon.ico",
      "signtoolOptions": {
        "publisherName": "Hart of the Midlands"
      },
      "target": [
        "portable",
        "nsis"
      ],
      "artifactName": "PP-MD-${version}-${arch}-${env.PPMD_FLAVOR}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Development",
      "artifactName": "PP-MD-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "PP-MD-${version}-${arch}.${ext}"
    }
  }
}
